APP_NAME=Calcolo Quote\nAPP_ENV=local\nAPP_DEBUG=true\nAPP_USERNAME=admin\nAPP_PASSWORD=change-me\n\n# Database locale SQLite\nDATABASE_URL=sqlite:///./football_odds_monitor.db\n\n# Seed dati demo locali.\n# Usare 0 in ambiente reale/demo.\nSEED_DEMO_DATA=0\n\n# Provider quote calcio\nODDS_PROVIDER=odds_api_io\n# Rate limit provider:
# se Odds-API.io restituisce 429, il software attiva un cooldown locale e blocca nuove chiamate provider.
# Non inserire mai chiavi reali in .env.example.\nODDS_API_KEY=bb6614b4ef5597a834ff0d3bec709c0a82c6c747490b6a7eb36e3b1f1c34ac3a\nODDS_API_BASE_URL=https://api.odds-api.io/v3\nODDS_API_SPORT=football\nODDS_API_STATUS=pending\n\n# Bookmaker supportati dal provider.\n# Attenzione: usare "Sbobet", non "SBOBET".\nODDS_API_BOOKMAKERS=Stake,Sbobet\n\n# Limite eventi richiesti al provider nei controlli manuali/provider.\nODDS_API_EVENT_LIMIT=10\n\n# Default iniziali scheduler.\n# Dopo il primo avvio, le impostazioni operative vengono gestite da dashboard/API\n# e salvate nella tabella scheduler_settings.\nODDS_SCHEDULER_ENABLED=0\nODDS_POLL_INTERVAL_SECONDS=300\nODDS_SCHEDULER_EVENT_LIMIT=1\n\n# Telegram\n# Creare un bot, inserire il token, avviare il server,\n# poi aprire il bot da Telegram e cliccare "Rileva account Telegram" in dashboard.\nTELEGRAM_BOT_TOKEN=\n\n# Fallback opzionale legacy.\n# Non richiesto se si usa il rilevamento account Telegram da dashboard.\nTELEGRAM_CHAT_ID=\n
