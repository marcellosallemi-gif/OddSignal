APP_NAME=Calcolo Quote
APP_ENV=local
APP_DEBUG=true

# Database locale SQLite
DATABASE_URL=sqlite:///./football_odds_monitor.db

# Seed dati demo locali.
# Usare 0 in ambiente reale/demo.
SEED_DEMO_DATA=0

# Provider quote calcio
ODDS_PROVIDER=odds_api_io
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.odds-api.io/v3
ODDS_API_SPORT=football
ODDS_API_STATUS=pending

# Bookmaker supportati dal provider.
# Attenzione: usare "Sbobet", non "SBOBET".
ODDS_API_BOOKMAKERS=Stake,Sbobet

# Limite eventi richiesti al provider nei controlli manuali/provider.
ODDS_API_EVENT_LIMIT=10

# Default iniziali scheduler.
# Dopo il primo avvio, le impostazioni operative vengono gestite da dashboard/API
# e salvate nella tabella scheduler_settings.
ODDS_SCHEDULER_ENABLED=0
ODDS_POLL_INTERVAL_SECONDS=300
ODDS_SCHEDULER_EVENT_LIMIT=1

# Telegram
# Creare un bot, inserire il token, avviare il server,
# poi aprire il bot da Telegram e cliccare "Rileva account Telegram" in dashboard.
TELEGRAM_BOT_TOKEN=

# Fallback opzionale legacy.
# Non richiesto se si usa il rilevamento account Telegram da dashboard.
TELEGRAM_CHAT_ID=
